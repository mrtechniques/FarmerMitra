# ─── FarmerMitra Backend Environment Variables ───────────────────────────────

# GEMINI_API_KEY: Required for AI-powered remedy generation and image validation.
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GEMINI_MODEL: The Gemini model to use for AI responses.
GEMINI_MODEL=gemini-2.0-flash

# PORT: The port the Flask server will listen on (default: 5050).
# PORT=5050
